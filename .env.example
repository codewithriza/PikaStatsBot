# ╔══════════════════════════════════════════════════════════════╗
# ║              PikaStatsBot Configuration                     ║
# ║  Copy this file to .env and fill in your values             ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Required ────────────────────────────────────────────────────
# Your Discord bot token (from https://discord.com/developers)
DISCORD_TOKEN=your_bot_token_here

# ── Optional ────────────────────────────────────────────────────
# Bot command prefix (for legacy text commands, default: !)
BOT_PREFIX=!

# Your Discord user ID (for owner-only commands)
OWNER_ID=0

# ── Vote Reminder Settings ──────────────────────────────────────
# Discord user ID to send daily vote reminders to (0 = disabled)
VOTE_REMINDER_USER_ID=0

# Hour to send the reminder (24h format, default: 18 = 6 PM)
VOTE_REMINDER_HOUR=18

# Timezone for the reminder (default: Asia/Kolkata)
VOTE_REMINDER_TIMEZONE=Asia/Kolkata
